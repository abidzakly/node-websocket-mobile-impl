# WebSocket Server Environment Variables
# Copy to .env and fill in values before running

# Port server berjalan
PORT=8080

# JWT Secret — GANTI dengan string random 256-bit di production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_256_bit_string_in_production

# Interval heartbeat ping (milliseconds)
HEARTBEAT_INTERVAL_MS=30000

# Log level: debug | info | warn | error
LOG_LEVEL=info
